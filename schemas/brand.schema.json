{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EthanY33/atelier/schemas/brand.schema.json",
  "title": "Atelier Brand Memory",
  "description": "Brand source of truth for the atelier design-automation plugin.",
  "type": "object",
  "required": ["brand", "palette", "typography"],
  "additionalProperties": false,
  "properties": {
    "brand": {
      "type": "object",
      "required": ["studio"],
      "additionalProperties": false,
      "properties": {
        "studio": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string"
        },
        "voice": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "palette": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_-]*$": {
          "type": "string",
          "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$"
        }
      }
    },
    "typography": {
      "type": "object",
      "required": ["body"],
      "additionalProperties": false,
      "properties": {
        "body": {
          "type": "string",
          "minLength": 1
        },
        "display": {
          "type": "string"
        },
        "mono": {
          "type": "string"
        }
      }
    },
    "logos": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mark": { "type": "string" },
        "wordmark": { "type": "string" }
      }
    },
    "social": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "enum": ["cloudflare-pages", "netlify", "github-pages", "vercel", "custom"]
        },
        "project": {
          "type": "string"
        },
        "stores": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["steam", "itch", "apple", "google"]
          }
        }
      }
    }
  }
}
